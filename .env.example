# ================================================
# Restaurant Platform - Environment Variables
# ================================================
# Copy this file to .env and fill in your values
# Never commit actual credentials to version control!

# ================================================
# Database Configuration
# ================================================
# PostgreSQL connection details
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/restaurant_db
SPRING_DATASOURCE_USERNAME=restaurant_user
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# ================================================
# JWT Security
# ================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_very_long_random_secret_key_at_least_32_characters_here

# ================================================
# Email Configuration (Gmail)
# ================================================
# Gmail address
SPRING_MAIL_USERNAME=your-email@gmail.com

# App-specific password from Google Account
# See: https://myaccount.google.com/apppasswords
SPRING_MAIL_PASSWORD=your_16_char_app_password_from_google

# From address for emails
SPRING_MAIL_FROM=noreply@restaurant-platform.com

# ================================================
# CORS Configuration
# ================================================
# Allowed origins for frontend requests
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-domain.com

# ================================================
# VNPay Payment Gateway (Optional)
# ================================================
# Register at: https://sandbox.vnpayment.vn
VNPAY_MERCHANT_ID=your_vnpay_merchant_id
VNPAY_HASH_SECRET=your_vnpay_hash_secret

# ================================================
# Momo Payment Gateway (Optional)
# ================================================
# Register at: https://sandbox.momomarket.vn
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key

# ================================================
# Redis Configuration (Optional)
# ================================================
# For caching and session management
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# ================================================
# Application URLs
# ================================================
# Frontend URL for email links and redirects
APP_FRONTEND_URL=http://localhost:3000

# API Base URL
APP_API_URL=http://localhost:8080

# ================================================
# Server Configuration
# ================================================
# Server port (default: 8080)
SERVER_PORT=8080

# Application name
APP_NAME=Restaurant Platform

# Application version
APP_VERSION=0.0.1-SNAPSHOT

# ================================================
# Logging Configuration
# ================================================
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ================================================
# Spring Profiles
# ================================================
# Options: dev, test, prod
SPRING_PROFILES_ACTIVE=dev
